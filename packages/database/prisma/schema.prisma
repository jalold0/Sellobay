// ===================================================================
// Sellobay — Prisma Schema (PostgreSQL on Neon)
// TZ v2.0 (2026-yil Iyun) — Sellobay marketplace ekotizimi
// Domains: Users, Catalog, Orders, Inventory, Warehouses, Marketing,
//          Couriers, CRM, Finance, Reviews, Sellers, Notifications
// ===================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm]
}

// ===================================================================
// ENUMS
// ===================================================================

enum UserRole {
  CUSTOMER
  SELLER
  COURIER
  WAREHOUSE_STAFF
  SUPPORT_AGENT
  MARKETING_MANAGER
  FINANCE_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
  DELETED
}

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

enum AuthProvider {
  PHONE
  EMAIL
  GOOGLE
  APPLE
  TELEGRAM
}

enum AddressType {
  HOME
  WORK
  PICKUP
  OTHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
  CANCELLED
}

enum PaymentProvider {
  CLICK
  PAYME
  UZUM_BANK
  UZCARD
  HUMO
  VISA
  MASTERCARD
  CASH_ON_DELIVERY
}

enum DeliveryMethod {
  HOME_DELIVERY
  PICKUP_POINT
  EXPRESS
}

enum DeliveryStatus {
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  ARRIVED
  DELIVERED
  FAILED
  RETURNED
}

enum StockMovementType {
  RECEIVING
  DISPATCH
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  RETURN
  RESERVATION
  RELEASE_RESERVATION
}

enum PromoType {
  PERCENT
  FIXED
  FREE_SHIPPING
  BXGY
}

enum CampaignChannel {
  PUSH
  SMS
  EMAIL
  TELEGRAM
  IN_APP
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
  TELEGRAM
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  READ
}

// ===================================================================
// USERS & AUTH
// ===================================================================

model User {
  id              String      @id @default(uuid()) @db.Uuid
  phone           String?     @unique
  email           String?     @unique
  passwordHash    String?
  firstName       String?
  lastName        String?
  birthDate       DateTime?   @db.Date
  gender          Gender      @default(UNSPECIFIED)
  avatarUrl       String?
  locale          String      @default("uz")
  status          UserStatus  @default(PENDING)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastLoginAt     DateTime?
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String?
  loyaltyPoints    Int        @default(0)
  referralCode     String?    @unique
  referredById     String?    @db.Uuid
  referredBy       User?      @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals        User[]     @relation("Referrals")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  roles           UserRoleAssignment[]
  identities      UserIdentity[]
  addresses       UserAddress[]
  sessions        UserSession[]
  paymentMethods  PaymentMethod[]
  orders          Order[]
  carts           Cart[]
  wishlist        WishlistItem[]
  reviews         Review[]
  questions       ProductQuestion[]
  notifications   Notification[]
  tickets         SupportTicket[]
  seller          Seller?
  courierProfile  Courier?
  auditLogs       AuditLog[]
  segments        CustomerSegmentMembership[]
  loyaltyTxns     LoyaltyTransaction[]
  coupons         UserCoupon[]
  pushTokens      PushToken[]
  refreshTokens   RefreshToken[]
  otpCodes        OtpCode[]

  @@index([phone])
  @@index([email])
  @@index([status])
}

model UserRoleAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  role      UserRole
  scope     String?  // e.g. seller_id, warehouse_id
  grantedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, scope])
  @@index([role])
}

model UserIdentity {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @db.Uuid
  provider     AuthProvider
  providerUid  String
  meta         Json?
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@index([userId])
}

model UserAddress {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  label         String?
  type          AddressType @default(HOME)
  recipientName String
  phone         String
  country       String      @default("UZ")
  region        String
  city          String
  district      String?
  street        String
  building      String?
  apartment     String?
  postalCode    String?
  landmark      String?
  latitude      Decimal?    @db.Decimal(10, 7)
  longitude     Decimal?    @db.Decimal(10, 7)
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@index([userId])
}

model UserSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  deviceId     String?
  deviceName   String?
  ipAddress    String?
  userAgent    String?
  lastSeenAt   DateTime @default(now())
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedById String?  @db.Uuid
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OtpCode {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @db.Uuid
  channel    AuthProvider
  recipient  String    // phone or email
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recipient, channel])
}

model PushToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  platform  String   // ios | android | web
  appName   String?  // customer | courier
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===================================================================
// CATALOG: Categories, Brands, Products, Variants
// ===================================================================

model Category {
  id           String      @id @default(uuid()) @db.Uuid
  parentId     String?     @db.Uuid
  slug         String      @unique
  name         Json        // { uz, ru, en }
  description  Json?
  iconUrl      String?
  bannerUrl    String?
  position     Int         @default(0)
  isActive     Boolean     @default(true)
  metaTitle    Json?
  metaDescription Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  parent       Category?   @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]  @relation("CategoryTree")
  products     ProductCategory[]
  attributes   CategoryAttribute[]

  @@index([parentId])
  @@index([slug])
}

model Brand {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String
  logoUrl     String?
  description Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]

  @@index([slug])
}

model Attribute {
  id          String                @id @default(uuid()) @db.Uuid
  slug        String                @unique
  name        Json
  type        String                // string | number | boolean | color | size
  unit        String?
  isFilter    Boolean               @default(true)
  isVariant   Boolean               @default(false)
  createdAt   DateTime              @default(now())
  options     AttributeOption[]
  categoryRel CategoryAttribute[]
  variantRel  VariantAttribute[]
}

model AttributeOption {
  id           String     @id @default(uuid()) @db.Uuid
  attributeId  String     @db.Uuid
  value        String     // e.g. "Red", "XL"
  label        Json
  swatchHex    String?
  position     Int        @default(0)
  attribute    Attribute  @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, value])
}

model CategoryAttribute {
  categoryId  String   @db.Uuid
  attributeId String   @db.Uuid
  isRequired  Boolean  @default(false)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([categoryId, attributeId])
}

model Product {
  id              String              @id @default(uuid()) @db.Uuid
  sellerId        String?             @db.Uuid
  brandId         String?             @db.Uuid
  slug            String              @unique
  sku             String              @unique
  name            Json                // { uz, ru, en }
  description     Json
  shortDescription Json?
  status          ProductStatus       @default(DRAFT)
  isFeatured      Boolean             @default(false)
  basePrice       Decimal             @db.Decimal(14, 2)
  compareAtPrice  Decimal?            @db.Decimal(14, 2)
  currency        String              @default("UZS")
  taxRate         Decimal             @default(0) @db.Decimal(5, 2)
  weightGrams     Int?
  metaTitle       Json?
  metaDescription Json?
  searchVector    Unsupported("tsvector")?
  rating          Decimal             @default(0) @db.Decimal(3, 2)
  reviewCount     Int                 @default(0)
  soldCount       Int                 @default(0)
  publishedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  seller          Seller?             @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  brand           Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categories      ProductCategory[]
  images          ProductImage[]
  variants        ProductVariant[]
  reviews         Review[]
  questions       ProductQuestion[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  wishlistItems   WishlistItem[]

  @@index([sellerId])
  @@index([brandId])
  @@index([status])
  @@index([slug])
  @@index([searchVector], type: Gin)
}

model ProductCategory {
  productId  String   @db.Uuid
  categoryId String   @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @db.Uuid
  url       String
  alt       Json?
  position  Int     @default(0)
  isPrimary Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @db.Uuid
  sku         String   @unique
  barcode     String?  @unique
  price       Decimal? @db.Decimal(14, 2)
  compareAtPrice Decimal? @db.Decimal(14, 2)
  weightGrams Int?
  position    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes  VariantAttribute[]
  inventory   InventoryItem[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([productId])
}

model VariantAttribute {
  variantId    String          @db.Uuid
  attributeId  String          @db.Uuid
  optionId     String?         @db.Uuid
  valueString  String?
  valueNumber  Decimal?        @db.Decimal(14, 4)
  valueBoolean Boolean?
  variant      ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute    Attribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeId])
}

// ===================================================================
// REVIEWS, RATINGS, Q&A
// ===================================================================

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @db.Uuid
  userId      String   @db.Uuid
  orderId     String?  @db.Uuid
  rating      Int      // 1-5
  title       String?
  body        String?
  images      String[]
  isVerifiedPurchase Boolean @default(false)
  isApproved  Boolean  @default(false)
  helpfulCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([productId, userId, orderId])
  @@index([productId])
}

model ProductQuestion {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @db.Uuid
  userId     String   @db.Uuid
  question   String
  answer     String?
  answeredBy String?  @db.Uuid
  answeredAt DateTime?
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ===================================================================
// CART, WISHLIST
// ===================================================================

model Cart {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String?    @db.Uuid
  sessionId  String?    // mehmonlar uchun
  currency   String     @default("UZS")
  abandonedAt DateTime?
  recoveryEmailSentAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items      CartItem[]

  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id         String          @id @default(uuid()) @db.Uuid
  cartId     String          @db.Uuid
  productId  String          @db.Uuid
  variantId  String?         @db.Uuid
  quantity   Int             @default(1)
  unitPrice  Decimal         @db.Decimal(14, 2)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  cart       Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
}

model WishlistItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ===================================================================
// ORDERS, PAYMENTS, SHIPMENTS
// ===================================================================

model Order {
  id              String         @id @default(uuid()) @db.Uuid
  number          String         @unique // human-readable, e.g. ORD-2026-00001234
  userId          String?        @db.Uuid
  guestEmail      String?
  guestPhone      String?
  status          OrderStatus    @default(PENDING)
  currency        String         @default("UZS")
  subtotal        Decimal        @db.Decimal(14, 2)
  discountTotal   Decimal        @default(0) @db.Decimal(14, 2)
  taxTotal        Decimal        @default(0) @db.Decimal(14, 2)
  shippingTotal   Decimal        @default(0) @db.Decimal(14, 2)
  grandTotal      Decimal        @db.Decimal(14, 2)
  paidTotal       Decimal        @default(0) @db.Decimal(14, 2)
  refundedTotal   Decimal        @default(0) @db.Decimal(14, 2)
  locale          String         @default("uz")
  notes           String?
  promoCode       String?
  shippingAddressId String?      @db.Uuid
  deliveryMethod  DeliveryMethod @default(HOME_DELIVERY)
  placedAt        DateTime       @default(now())
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  shippingAddress UserAddress?   @relation(fields: [shippingAddressId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  payments        Payment[]
  deliveries      Delivery[]
  statusHistory   OrderStatusHistory[]
  reviews         Review[]
  invoices        Invoice[]

  @@index([userId])
  @@index([status])
  @@index([placedAt])
}

model OrderItem {
  id          String          @id @default(uuid()) @db.Uuid
  orderId     String          @db.Uuid
  productId   String          @db.Uuid
  variantId   String?         @db.Uuid
  sellerId    String?         @db.Uuid
  sku         String
  nameSnapshot Json
  quantity    Int
  unitPrice   Decimal         @db.Decimal(14, 2)
  discount    Decimal         @default(0) @db.Decimal(14, 2)
  taxRate     Decimal         @default(0) @db.Decimal(5, 2)
  totalPrice  Decimal         @db.Decimal(14, 2)
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  seller      Seller?         @relation(fields: [sellerId], references: [id])

  @@index([orderId])
}

model OrderStatusHistory {
  id        String      @id @default(uuid()) @db.Uuid
  orderId   String      @db.Uuid
  status    OrderStatus
  comment   String?
  changedBy String?     @db.Uuid
  changedAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id            String          @id @default(uuid()) @db.Uuid
  orderId       String          @db.Uuid
  provider      PaymentProvider
  status        PaymentStatus   @default(PENDING)
  amount        Decimal         @db.Decimal(14, 2)
  currency      String          @default("UZS")
  externalId    String?         // provider transaction id
  rawPayload    Json?
  paidAt        DateTime?
  failedAt      DateTime?
  refundedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([provider, externalId])
}

model PaymentMethod {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @db.Uuid
  provider    PaymentProvider
  brand       String?
  last4       String?
  expiryMonth Int?
  expiryYear  Int?
  token       String          // provider token (encrypted)
  isDefault   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===================================================================
// SELLERS (Marketplace)
// ===================================================================

model Seller {
  id              String         @id @default(uuid()) @db.Uuid
  ownerUserId     String         @unique @db.Uuid
  legalName       String
  brandName       String
  tin             String?        // STIR / INN
  registrationNo  String?
  email           String?
  phone           String?
  description     Json?
  logoUrl         String?
  status          SellerStatus   @default(PENDING)
  commissionRate  Decimal        @default(10) @db.Decimal(5, 2)
  rating          Decimal        @default(0) @db.Decimal(3, 2)
  bankAccount     String?
  bankName        String?
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  owner           User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  products        Product[]
  orderItems      OrderItem[]
  payouts         SellerPayout[]
  warehouses      Warehouse[]

  @@index([status])
}

model SellerPayout {
  id           String        @id @default(uuid()) @db.Uuid
  sellerId     String        @db.Uuid
  amount       Decimal       @db.Decimal(14, 2)
  currency     String        @default("UZS")
  periodStart  DateTime
  periodEnd    DateTime
  status       PaymentStatus @default(PENDING)
  paidAt       DateTime?
  reference    String?
  createdAt    DateTime      @default(now())
  seller       Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

// ===================================================================
// WAREHOUSES & INVENTORY (WMS)
// ===================================================================

model Warehouse {
  id          String     @id @default(uuid()) @db.Uuid
  sellerId    String?    @db.Uuid
  code        String     @unique
  name        String
  address     String
  city        String
  region      String?
  country     String     @default("UZ")
  latitude    Decimal?   @db.Decimal(10, 7)
  longitude   Decimal?   @db.Decimal(10, 7)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  seller      Seller?    @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  locations   WarehouseLocation[]
  inventory   InventoryItem[]
  movements   StockMovement[]
}

model WarehouseLocation {
  id           String     @id @default(uuid()) @db.Uuid
  warehouseId  String     @db.Uuid
  code         String     // shelf/bin code (e.g. A-12-03)
  description  String?
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventory    InventoryItem[]

  @@unique([warehouseId, code])
}

model InventoryItem {
  id              String              @id @default(uuid()) @db.Uuid
  warehouseId     String              @db.Uuid
  locationId      String?             @db.Uuid
  variantId       String              @db.Uuid
  quantityOnHand  Int                 @default(0)
  quantityReserved Int                @default(0)
  reorderPoint    Int                 @default(0)
  updatedAt       DateTime            @updatedAt
  warehouse       Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  location        WarehouseLocation?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  variant         ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, variantId, locationId])
  @@index([variantId])
}

model StockMovement {
  id              String             @id @default(uuid()) @db.Uuid
  warehouseId     String             @db.Uuid
  variantId       String             @db.Uuid
  type            StockMovementType
  quantity        Int
  reference       String?            // order id / transfer id / audit id
  reason          String?
  performedBy     String?            @db.Uuid
  createdAt       DateTime           @default(now())
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([warehouseId, variantId])
  @@index([createdAt])
}

// ===================================================================
// DELIVERY / COURIERS
// ===================================================================

model Courier {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @unique @db.Uuid
  vehicleType   String?       // bike, car, foot
  vehicleNumber String?
  isActive      Boolean       @default(true)
  rating        Decimal       @default(0) @db.Decimal(3, 2)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries    Delivery[]
}

model Delivery {
  id              String          @id @default(uuid()) @db.Uuid
  orderId         String          @db.Uuid
  courierId       String?         @db.Uuid
  status          DeliveryStatus  @default(ASSIGNED)
  method          DeliveryMethod  @default(HOME_DELIVERY)
  pickupAddress   String?
  destinationAddress String
  destinationLat  Decimal?        @db.Decimal(10, 7)
  destinationLng  Decimal?        @db.Decimal(10, 7)
  assignedAt      DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  failureReason   String?
  signatureUrl    String?
  proofPhotoUrl   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courier         Courier?        @relation(fields: [courierId], references: [id], onDelete: SetNull)
  events          DeliveryEvent[]

  @@index([orderId])
  @@index([courierId])
  @@index([status])
}

model DeliveryEvent {
  id          String         @id @default(uuid()) @db.Uuid
  deliveryId  String         @db.Uuid
  status      DeliveryStatus
  note        String?
  latitude    Decimal?       @db.Decimal(10, 7)
  longitude   Decimal?       @db.Decimal(10, 7)
  createdAt   DateTime       @default(now())
  delivery    Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
}

// ===================================================================
// MARKETING: Promos, Loyalty, Referrals, Campaigns
// ===================================================================

model PromoCode {
  id            String     @id @default(uuid()) @db.Uuid
  code          String     @unique
  type          PromoType
  value         Decimal    @db.Decimal(14, 2)
  minOrderTotal Decimal?   @db.Decimal(14, 2)
  maxDiscount   Decimal?   @db.Decimal(14, 2)
  usageLimit    Int?
  usagePerUser  Int        @default(1)
  usedCount     Int        @default(0)
  startsAt      DateTime?
  endsAt        DateTime?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  userCoupons   UserCoupon[]

  @@index([code])
}

model UserCoupon {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  promoCodeId String    @db.Uuid
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([userId, promoCodeId])
}

model LoyaltyTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  points    Int      // positive = earn, negative = spend
  reason    String   // ORDER_EARN, ORDER_SPEND, REFERRAL, ADJUSTMENT
  reference String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Campaign {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  description String?
  channel     CampaignChannel
  payload     Json
  segmentId   String?         @db.Uuid
  scheduledAt DateTime?
  sentAt      DateTime?
  metrics     Json?
  createdAt   DateTime        @default(now())
  segment     CustomerSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
}

// ===================================================================
// CRM: Segments, Tickets, Communications
// ===================================================================

model CustomerSegment {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  rules       Json     // segmentation rules
  isDynamic   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  memberships CustomerSegmentMembership[]
  campaigns   Campaign[]
}

model CustomerSegmentMembership {
  segmentId String          @db.Uuid
  userId    String          @db.Uuid
  addedAt   DateTime        @default(now())
  segment   CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([segmentId, userId])
}

model SupportTicket {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String?         @db.Uuid
  subject     String
  body        String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)
  assignedTo  String?         @db.Uuid
  orderId     String?         @db.Uuid
  closedAt    DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages    TicketMessage[]

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id        String         @id @default(uuid()) @db.Uuid
  ticketId  String         @db.Uuid
  authorId  String?        @db.Uuid
  body      String
  attachments String[]
  isInternal Boolean       @default(false)
  createdAt DateTime       @default(now())
  ticket    SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ===================================================================
// FINANCE
// ===================================================================

model Invoice {
  id          String        @id @default(uuid()) @db.Uuid
  number      String        @unique
  orderId     String        @db.Uuid
  amount      Decimal       @db.Decimal(14, 2)
  currency    String        @default("UZS")
  status      PaymentStatus @default(PENDING)
  issuedAt    DateTime      @default(now())
  paidAt      DateTime?
  pdfUrl      String?
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Transaction {
  id            String          @id @default(uuid()) @db.Uuid
  type          String          // CHARGE, REFUND, PAYOUT, COMMISSION
  amount        Decimal         @db.Decimal(14, 2)
  currency      String          @default("UZS")
  provider      PaymentProvider?
  reference     String?
  meta          Json?
  createdAt     DateTime        @default(now())

  @@index([type, createdAt])
}

// ===================================================================
// NOTIFICATIONS
// ===================================================================

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  channel   NotificationChannel
  title     String
  body      String
  data      Json?
  status    NotificationStatus  @default(QUEUED)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ===================================================================
// AUDIT LOG
// ===================================================================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  action    String
  resource  String
  resourceId String?
  ipAddress String?
  userAgent String?
  meta      Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
}
