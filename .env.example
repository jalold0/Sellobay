# ============================================
# E-Commerce Ekosistema — Environment shabloni
# .env.example dan nusxa olib .env yarating
# ============================================

NODE_ENV=development
TZ=Asia/Tashkent

# --- Asosiy ---
APP_NAME=ecommerce-ecosystem
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- PostgreSQL ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce?schema=public
DATABASE_SHADOW_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_shadow?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=ecom:

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PRODUCTS=products

# --- S3 / MinIO (Object Storage) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ecom-media
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- JWT ---
JWT_SECRET=change-me-in-production-with-strong-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-with-another-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- SMS (Eskiz / Playmobile) ---
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546
PLAYMOBILE_LOGIN=
PLAYMOBILE_PASSWORD=

# --- Email (SMTP / SendGrid) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="E-Commerce <noreply@example.uz>"

# --- O'zbekiston to'lov tizimlari ---
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=

PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_ENDPOINT=https://checkout.paycom.uz

UZUM_BANK_MERCHANT_ID=
UZUM_BANK_SECRET=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBAPP_URL=
TELEGRAM_WEBHOOK_URL=

# --- Instagram / Meta ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_ACCESS_TOKEN=
META_BUSINESS_ID=

# --- Observability ---
SENTRY_DSN=
PROMETHEUS_METRICS_PORT=9090
LOG_LEVEL=debug

# --- Rate Limiting ---
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# --- Frontend (Next.js public) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=uz
NEXT_PUBLIC_SUPPORTED_LOCALES=uz,ru,en
NEXT_PUBLIC_DEFAULT_CURRENCY=UZS
NEXT_PUBLIC_TELEGRAM_BOT=
NEXT_PUBLIC_SENTRY_DSN=

# --- Mobile (Expo public) ---
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_APP_NAME=ecommerce
