{
  "expo": {
    "name": "E-Commerce Courier",
    "slug": "ecom-courier",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "ecomcourier",
    "userInterfaceStyle": "automatic",
    "ios": { "bundleIdentifier": "uz.example.ecom.courier" },
    "android": { "package": "uz.example.ecom.courier" },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-camera"
    ]
  }
}
